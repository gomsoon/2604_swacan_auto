[Unit]
Description=SWA Runtime Monitor Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=swacan
Group=swacan
WorkingDirectory=/opt/swacan-agent
ExecStart=/usr/bin/python3.11 -m agent --config /opt/swacan-agent/agent.toml
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/swacan-agent

[Install]
WantedBy=multi-user.target
